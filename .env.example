# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=mapping_party

# OpenStreetMap OAuth2
OSM_CLIENT_ID=your_osm_client_id
OSM_CLIENT_SECRET=your_osm_client_secret

# Session security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change_this_to_a_random_secret_key

# Base URL for OAuth callback (no trailing slash)
BASE_URL=http://localhost:8000
